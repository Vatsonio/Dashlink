{$DOMAIN:localhost} {
	# Frontend
	handle {
		reverse_proxy frontend:3000
	}

	# API proxy
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}
