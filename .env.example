# === Dashlink Configuration ===

# Domain for Caddy HTTPS (use "localhost" for local dev)
DOMAIN=localhost

# Ports
HTTP_PORT=80
HTTPS_PORT=443

# Backend
DL_DEBUG=false
DL_SCAN_INTERVAL=30

# Optional: PIN code for dashboard access
# DL_PIN_CODE=1234

# Optional: Override host IP for service URLs (auto-detected if empty)
# HOST_IP=192.168.31.5
